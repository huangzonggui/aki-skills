# Copy the lines you need into your centralized AI keys file.
# MacBook default: /Users/aki/.config/ai/keys.env
# Hermes/Linux fallback: ~/.config/ai/keys.env
# Keep real credentials out of this repository.

AIU_PROFILE=cygces

# dshub.top / new-api compatible relay
DSHUB_BASE=https://api.dshub.top
DSHUB_API_STYLE=new-api
DSHUB_USERNAME=your-dshub-username
DSHUB_PASSWORD=your-d...word
DSHUB_API_KEY=***
DSHUB_INTERVAL=30

# cygces / Token Wave / Sub2API manager used by Hermes Codex traffic
CYGCES_BASE=https://codex-manager.cygces.com
CYGCES_API_STYLE=sub2api
CYGCES_USERNAME=your-cygces-email
CYGCES_PASSWORD=your-c...word
CYGCES_HERMES_API_KEY=***
CYGCES_INTERVAL=30
