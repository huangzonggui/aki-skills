# Copy the lines you need into /Users/aki/.config/ai/keys.env.
# Keep real credentials out of this repository.

AIU_PROFILE=cygces

DSHUB_BASE=https://api.dshub.top
DSHUB_USERNAME=your-dshub-username
DSHUB_PASSWORD=your-dshub-password
DSHUB_API_KEY=sk-your-dshub-api-key

CYGCES_BASE=https://codex-manager.cygces.com
CYGCES_USERNAME=your-cygces-email
CYGCES_PASSWORD=your-cygces-password
CYGCES_HERMES_API_KEY=sk-your-cygces-api-key
