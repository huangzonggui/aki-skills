# ============================================================
# Aki Content Pipeline Pro - API Key Configuration
# ============================================================
# Copy this file to ~/.config/ai/keys.env and fill in your keys:
#   cp config/keys.env.example ~/.config/ai/keys.env
# ============================================================

# Required: Comfly AI for image generation
# Sign up: https://ai.comfly.chat
COMFLY_API_KEY=sk-your-key-here
COMFLY_IMAGE_MODEL=gpt-image-2

# Optional: OpenRouter as fallback image provider
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: LLM model for content planning (defaults to gemini-3-pro-preview-thinking)
COMFLY_CHAT_MODEL=gemini-3-pro-preview-thinking

# Optional: WeChat Official Account API (for publish step)
# Get from: https://mp.weixin.qq.com > Settings > Developer
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret
